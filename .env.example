# GWorkspace AI Agent - Environment Configuration
# Copy this to .env and fill in the values

# ── Application ──────────────────────────────────────
APP_NAME="GWorkspace AI Agent"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
# Local-only default: do not expose service to LAN/public network
HOST=127.0.0.1
PORT=8000

# ── Mock Mode (set to false when you have real Google credentials) ──
# Set to true to bypass real Google API calls during development
MOCK_MODE=true

# ── Google OAuth 2.0 ─────────────────────────────────
# Get these from Google Cloud Console (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback
# Path to your client_secret.json if not using individual env vars
GOOGLE_CREDENTIALS_FILE=

# ── LLM Configuration ───────────────────────────────
LLM_PROVIDER=google
LLM_MODEL=gemini-3-flash-preview
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# For Google AI Studio (LLM_PROVIDER=google)
GOOGLE_API_KEY=

# For Vertex AI (LLM_PROVIDER=vertex)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global

# ── Database ─────────────────────────────────────────
# SQLite is default for local development
DATABASE_URL=sqlite:///data/gworkspace.db
# Key used to encrypt Google OAuth tokens in the database (32-byte base64)
# You can generate one using: python -c "import secrets; print(secrets.token_urlsafe(32))"
TOKEN_ENCRYPTION_KEY=

# ── HITL (Human-in-the-Loop) ───────────────────────
HITL_APPROVAL_TIMEOUT_SECONDS=3600
HITL_MAX_PENDING_PER_USER=50

# ── Execution Controls ──────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
TOOL_TIMEOUT_SECONDS=30
TOOL_MAX_RETRIES=3
